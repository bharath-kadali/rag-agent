GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Local Docker: http://localhost:6333 — Render/production: use Qdrant Cloud HTTPS URL from cloud.qdrant.io
QDRANT_URL=http://localhost:6333
# Qdrant Cloud: paste API key from cluster dashboard (empty for local Qdrant)
QDRANT_API_KEY=
APP_DATA_DIR=./data
CORS_ORIGINS=http://localhost:5173